<?xml version="1.0" encoding="utf-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SnapStakMobile.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <!-- SnapStak brand colors -->
            <Color x:Key="BgDeep">#0A0A0F</Color>
            <Color x:Key="BgCard">#13131A</Color>
            <Color x:Key="BorderSubtle">#2A2A3D</Color>
            <Color x:Key="AccentBlue">#1BC8F0</Color>
            <Color x:Key="TextPrimary">#F0F0FF</Color>
            <Color x:Key="TextSecondary">#7878A0</Color>
            <Color x:Key="TextMuted">#4A4A6A</Color>
            <Color x:Key="Danger">#EF4444</Color>
        </ResourceDictionary>
    </Application.Resources>
</Application>
